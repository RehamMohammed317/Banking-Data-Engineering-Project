    [Saving Accounts] AS SavingAccounts,
    [Foreign Currency Account] AS ForeignCurrencyAccount,
    [Business Lending] AS BusinessLending,
[Risk Weighting],
 CAST(GETDATE() AS DATE) AS Date,
CAST(GETDATE() AS TIME) As time,
    
    [Amount of Credit Cards] AS AmountOfCreditCards,
    [Properties Owned] AS PropertiesOwned

FROM Banking_cleaned;</property>
